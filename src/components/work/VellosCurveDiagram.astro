---
// Vellos — the bonding-curve mechanic. A token launches from a factory onto a
// constant-product (virtual-reserve) curve where price is pure supply & demand;
// when the curve sells out, liquidity graduates into an AMM pool (LP locked).
// Colours inherit the page --accent (green); borders are black, per the system.
---

<figure class="diag">
  <svg viewBox="0 0 960 600" role="img" aria-label="A creator launches a token via a factory onto a constant-product bonding curve. Price rises as tokens sell; when the curve fills, liquidity migrates to an AMM pool with the LP locked.">
    <defs>
      <marker id="vcah" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0 0 L10 5 L0 10 z" fill="#000" />
      </marker>
    </defs>

    <!-- top flow row -->
    <g class="node">
      <rect x="40" y="40" width="150" height="72" rx="4" />
      <text class="t-md" x="115" y="74">CREATOR</text>
      <text class="t-sm" x="115" y="94">launches a token</text>
    </g>
    <g class="node">
      <rect x="250" y="40" width="180" height="72" rx="4" />
      <text class="t-md" x="340" y="74">TOKEN FACTORY</text>
      <text class="t-sm" x="340" y="94">EIP-1167 clone</text>
    </g>
    <g class="node node--accent">
      <rect x="500" y="40" width="190" height="72" rx="4" />
      <text class="t-md" x="595" y="74">BONDING CURVE</text>
      <text class="t-sm" x="595" y="94">buy / sell on-chain</text>
    </g>
    <g class="node">
      <rect x="740" y="40" width="180" height="72" rx="4" />
      <text class="t-md" x="830" y="74">AMM POOL</text>
      <text class="t-sm" x="830" y="94">graduated · LP locked</text>
    </g>

    <path class="edge" d="M190 76 L244 76" marker-end="url(#vcah)" />
    <path class="edge" d="M430 76 L494 76" marker-end="url(#vcah)" />
    <text class="e-lbl" x="462" y="30">launches</text>
    <path class="edge" d="M690 76 L734 76" marker-end="url(#vcah)" />
    <text class="e-lbl" x="712" y="30">graduate</text>

    <!-- graph: price vs tokens sold -->
    <path class="area" d="M150 502 C 430 498 610 478 705 410 C 760 370 788 290 806 222 L806 520 L150 520 Z" />
    <line class="axis" x1="150" y1="200" x2="150" y2="520" />
    <line class="axis" x1="150" y1="520" x2="842" y2="520" marker-end="url(#vcah)" />
    <text class="ax" x="150" y="186">PRICE ↑</text>
    <text class="ax ax--end" x="840" y="546">TOKENS SOLD →</text>

    <path class="curve" d="M150 502 C 430 498 610 478 705 410 C 760 370 788 290 806 222" />

    <!-- formula -->
    <text class="formula" x="180" y="252">price = X / Y</text>
    <text class="formula" x="180" y="278">buy Δy → pay  X·Δy / (Y − Δy)</text>
    <text class="formula formula--dim" x="180" y="300">virtual reserves · X · Y = k</text>

    <text class="mv" x="430" y="352">each BUY moves up the curve · each SELL moves down</text>

    <!-- graduation callout -->
    <line class="edge edge--dash" x1="704" y1="236" x2="799" y2="224" />
    <text class="glabel ax--end" x="700" y="232">GRADUATION</text>
    <text class="glabel-sub ax--end" x="700" y="250">curve fills → migrate to AMM</text>
    <circle class="grad" cx="806" cy="222" r="7" />
  </svg>
</figure>

<style>
  .diag { margin: 0; }
  .diag svg { width: 100%; height: auto; display: block; background: var(--c-white); }
  .node rect { fill: var(--c-white); stroke: var(--c-black); stroke-width: 3; }
  .node--accent rect { fill: var(--accent, var(--c-gold)); }
  .node text { fill: var(--c-black); text-anchor: middle; font-family: var(--font-display); }
  .t-md { font-size: 23px; }
  .t-sm {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 13px;
    fill: color-mix(in srgb, var(--c-black) 72%, transparent);
    text-anchor: middle;
  }
  .edge { fill: none; stroke: var(--c-black); stroke-width: 2.5; }
  .edge--dash { stroke-dasharray: 6 5; opacity: 0.7; }
  .e-lbl {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    fill: var(--c-black);
    text-anchor: middle;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .axis { stroke: var(--c-black); stroke-width: 2.5; }
  .area { fill: var(--accent, var(--c-gold)); opacity: 0.14; }
  .curve { fill: none; stroke: var(--accent, var(--c-gold)); stroke-width: 4; stroke-linecap: round; }
  .ax {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.08em;
    fill: color-mix(in srgb, var(--c-black) 70%, transparent);
    text-anchor: start;
  }
  .ax--end { text-anchor: end; }
  .formula {
    font-family: "SF Mono", ui-monospace, Menlo, monospace;
    font-weight: 600;
    font-size: 17px;
    fill: var(--c-black);
    text-anchor: start;
  }
  .formula--dim { font-size: 14px; fill: color-mix(in srgb, var(--c-black) 60%, transparent); }
  .mv {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.03em;
    fill: color-mix(in srgb, var(--accent) 55%, #000);
    text-anchor: middle;
    text-transform: uppercase;
  }
  .grad { fill: var(--accent, var(--c-gold)); stroke: var(--c-black); stroke-width: 3; }
  .glabel {
    font-family: var(--font-display);
    font-size: 18px;
    fill: var(--c-black);
  }
  .glabel-sub {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 12px;
    fill: color-mix(in srgb, var(--c-black) 66%, transparent);
  }
</style>
