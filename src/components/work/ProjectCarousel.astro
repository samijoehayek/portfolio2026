---
// One-card-at-a-time project carousel (Dave-Holloway style).
// Layout mirrors DH: left column = black header (wordmark) + info pane;
// right column = the media image spanning the FULL card height (gets the shader).
import { projects, total } from "../../data/projects";
const pad = (n: number) => String(n).padStart(2, "0");
---

<div class="work__carousel" data-carousel>
  <div class="carousel__stage" data-stage>
    {
      projects.map((p, i) => (
        <article
          class="work__card"
          data-slide={i}
          data-active={i === 0 ? "" : undefined}
          aria-hidden={i === 0 ? "false" : "true"}
          style={`--accent:${p.accent}`}
        >
          <div class="card__left">
            <header class="card__head">
              <span class="card__wordmark">{p.client}</span>
            </header>
            <div class="card__info">
              <p class="card__label">CLIENT</p>
              <p class="card__client">{p.client}</p>
              <p class="card__role">{p.role}</p>
              <ul class="card__tags">
                {p.tags.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>
              <div class="card__foot">
                <a
                  class="card__cta"
                  href={p.href ?? undefined}
                  aria-disabled={p.href ? undefined : "true"}
                  target={p.href ? "_blank" : undefined}
                  rel={p.href ? "noopener noreferrer" : undefined}
                >
                  <span>VIEW WORK</span>
                  <span class="card__arrow">&rarr;</span>
                </a>
                <span class="card__count">
                  {pad(p.index)}<i>/</i>{pad(total)}
                </span>
              </div>
              <span class="sr-only">{p.blurb}</span>
            </div>
          </div>

          <div
            class="card__preview"
            data-pane
            data-img={p.image}
            data-depth={p.depth}
            data-accent={p.accent}
            aria-hidden="true"
          >
            <img class="preview__img" src={p.image} alt="" decoding="async" />
            <canvas class="preview__canvas"></canvas>
            <span class="card__preview-mark">{p.client}</span>
          </div>
        </article>
      ))
    }
  </div>

  <button class="carousel__arrow carousel__arrow--prev" data-prev aria-label="Previous project">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 4 L7 12 L15 20" /></svg>
  </button>
  <button class="carousel__arrow carousel__arrow--next" data-next aria-label="Next project">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 4 L17 12 L9 20" /></svg>
  </button>

  <p class="sr-only" data-live aria-live="polite"></p>
</div>

<style>
  /* wrapper is NOT positioned, so the arrows resolve to the SECTION (.work) and
     sit at the screen edges; the stage (z3) stays tucked under the hill (z4). */
  .work__carousel {
    width: min(90vw, 1240px); /* a little wider */
  }

  .carousel__stage {
    position: relative;
    z-index: 3;
    width: 100%;
    min-height: clamp(400px, 47vw, 675px); /* ~25% taller */
  }

  /* ── the card ──────────────────────────────────────────── */
  .work__card {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: clamp(400px, 47vw, 675px); /* ~25% taller */
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    border: 3px solid var(--c-black);
    border-radius: 12px;
    overflow: hidden;
    background: var(--c-white);
    box-shadow: 0 26px 55px rgba(0, 0, 0, 0.26);
    will-change: transform, opacity;
  }
  .work__card:not([data-active]) {
    opacity: 0;
    pointer-events: none;
  }

  .card__left {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .card__head {
    background: var(--c-black);
    padding: clamp(1.5rem, 4vw, 2.7rem) clamp(1rem, 2.4vw, 1.9rem); /* even taller title bar */
  }
  .card__wordmark {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.3rem, 6.2vw, 5.2rem);
    line-height: 0.86;
    color: var(--c-white);
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: clip;
  }
  .card__info {
    --info-pad: clamp(1.1rem, 2.4vw, 2rem);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(0.45rem, 1.3vw, 0.95rem);
    padding: var(--info-pad);
    background: color-mix(in srgb, var(--accent, var(--c-black)) 7%, var(--c-white));
  }
  .card__label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--c-black) 70%, transparent);
  }
  .card__client {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.4vw, 3.4rem);
    line-height: 0.92;
  }
  .card__role {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(0.8rem, 1.15vw, 0.95rem);
    color: color-mix(in srgb, var(--c-black) 62%, transparent);
  }
  /* tech line + tags = ONE entity: a full-width line (touches the card borders)
     with the downward triangles hanging directly off it. */
  .card__tags {
    margin-top: 0.6rem;
    margin-inline: calc(-1 * var(--info-pad));
    padding: 0 var(--info-pad);
    border-top: 2px solid var(--c-black);
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.9rem, 2.4vw, 2rem);
    list-style: none;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.07em;
  }
  .card__tags li {
    position: relative;
    padding-top: 0.95rem; /* room beneath the triangle for the label */
  }
  .card__tags li::before {
    content: "";
    position: absolute;
    top: 0; /* flat top flush against the line = one entity */
    left: 0;
    border: 6px solid transparent;
    border-top-color: var(--accent, var(--c-black));
  }
  .card__foot {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding-top: clamp(0.8rem, 2vw, 1.6rem);
  }
  .card__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 2px solid var(--c-black);
    border-radius: 0; /* squared off, like Dave's */
    padding: clamp(0.65rem, 1.5vw, 0.95rem) clamp(0.85rem, 1.7vw, 1.25rem);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.7vw, 1.4rem);
    text-decoration: none;
    color: var(--c-black);
    transition: background 0.18s ease, color 0.18s ease;
  }
  .card__cta[aria-disabled="true"] { opacity: 0.4; pointer-events: none; }
  .card__cta:hover { background: var(--c-gold); }
  .card__arrow { border-left: 2px solid var(--c-black); padding-left: 0.8rem; }
  .card__count {
    align-self: flex-end;
    font-family: var(--font-display);
    font-size: 0.95rem;
  }
  .card__count i { font-style: normal; opacity: 0.4; padding: 0 0.15em; }

  /* ── preview pane (image + shader canvas), full card height ─ */
  /* solid BLACK pane; the image is inset into it = a thick black frame with
     square inner corners and NO white gap. The card's rounding only clips the
     black pane's outer corners. */
  .card__preview {
    position: relative;
    overflow: hidden;
    background: var(--c-black);
  }
  .preview__img,
  .preview__canvas {
    position: absolute;
    top: 18px; /* thick top/right/bottom frame */
    left: 3px; /* thin divider, like the card border */
    width: calc(100% - 21px);
    height: calc(100% - 36px);
    display: block;
  }
  .preview__img { object-fit: cover; }
  .preview__canvas { opacity: 0; transition: opacity 0.22s ease; }
  .card__preview[data-shader-on] .preview__canvas { opacity: 1; }
  .card__preview[data-shader-on] .preview__img { opacity: 0; }
  .card__preview-mark {
    position: absolute;
    inset: 0;
    z-index: -1;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(2rem, 5vw, 4rem);
    color: var(--c-white);
    opacity: 0.4;
  }

  /* ── arrows: dark circles pinned to the screen edges ──── */
  /* big black CIRCLES that sit ~⅓ off the screen edges (like Dave's) */
  .carousel__arrow {
    --arrow-d: clamp(96px, 9vw, 132px);
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 6;
    width: var(--arrow-d);
    height: var(--arrow-d);
    border-radius: 50%;
    display: grid;
    place-items: center;
    border: none;
    background: var(--c-black);
    color: var(--c-white);
    cursor: pointer;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.32);
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .carousel__arrow svg {
    width: 34%;
    height: auto;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .carousel__arrow:hover { background: var(--c-gold); color: var(--c-black); }
  .carousel__arrow:active { transform: translateY(-50%) scale(0.94); }
  /* cut exactly at the center = true semicircle */
  .carousel__arrow--prev { left: calc(-0.5 * var(--arrow-d)); }
  .carousel__arrow--next { right: calc(-0.5 * var(--arrow-d)); }
  .carousel__arrow--prev svg { transform: translateX(calc(0.2 * var(--arrow-d))); } /* nudge glyph into the visible half */
  .carousel__arrow--next svg { transform: translateX(calc(-0.2 * var(--arrow-d))); }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  /* ── mobile ────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .work__carousel { width: min(92vw, 520px); }
    .work__card { grid-template-columns: 1fr; }
    .card__preview { min-height: 190px; order: 2; }
    .card__wordmark { font-size: 13vw; }
    .carousel__arrow { --arrow-d: 80px; }
    .carousel__arrow--prev { left: calc(-0.5 * var(--arrow-d)); }
    .carousel__arrow--next { right: calc(-0.5 * var(--arrow-d)); }
  }
</style>

<script>
  import { initCarousel } from "../../scripts/carousel";
  initCarousel();
  // lazy-load the Three.js liquid-glass shader as its own chunk (skip if reduced-motion)
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    import("../../scripts/pixelDistortion")
      .then((m) => m.initShaders())
      .catch(() => {});
  }
</script>
