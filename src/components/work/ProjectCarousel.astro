---
// One-card-at-a-time project carousel (Dave-Holloway style).
// Layout mirrors DH: left column = black header (wordmark) + info pane;
// right column = the media image spanning the FULL card height (gets the shader).
import { projects, total } from "../../data/projects";
const pad = (n: number) => String(n).padStart(2, "0");
---

<div class="work__carousel" data-carousel>
  <div class="carousel__stage" data-stage>
    {
      projects.map((p, i) => (
        <article
          class="work__card"
          data-slide={i}
          data-active={i === 0 ? "" : undefined}
          aria-hidden={i === 0 ? "false" : "true"}
          style={`--accent:${p.accent}`}
        >
          <div class="card__left">
            <header class="card__head">
              <span class="card__wordmark">{p.client}</span>
            </header>
            <div class="card__info">
              <p class="card__label">CLIENT</p>
              <p class="card__client">{p.client}</p>
              <p class="card__role">{p.role}</p>
              <ul class="card__tags">
                {p.tags.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>
              <div class="card__foot">
                <a
                  class="card__cta"
                  href={p.slug ? `/work/${p.slug}` : undefined}
                  data-work-cta={p.slug ? "" : undefined}
                  data-accent={p.accent}
                  aria-disabled={p.slug ? undefined : "true"}
                >
                  <span>VIEW WORK</span>
                  <span class="card__arrow">&rarr;</span>
                </a>
                <span class="card__count">
                  {pad(p.index)}<i>/</i>{pad(total)}
                </span>
              </div>
              <span class="sr-only">{p.blurb}</span>
            </div>
          </div>

          <div
            class="card__preview"
            data-pane
            data-img={p.image}
            data-depth={p.depth}
            data-accent={p.accent}
            aria-hidden="true"
          >
            <img class="preview__img" src={p.image} alt="" decoding="async" />
            <canvas class="preview__canvas"></canvas>
            <span class="card__preview-mark">{p.client}</span>
          </div>
        </article>
      ))
    }
  </div>

  <button class="carousel__arrow carousel__arrow--prev" data-prev aria-label="Previous project">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 4 L7 12 L15 20" /></svg>
  </button>
  <button class="carousel__arrow carousel__arrow--next" data-next aria-label="Next project">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 4 L17 12 L9 20" /></svg>
  </button>

  <p class="sr-only" data-live aria-live="polite"></p>
</div>

<style>
  /* wrapper is NOT positioned, so the arrows resolve to the SECTION (.work) and
     sit at the screen edges; the stage (z3) stays tucked under the hill (z4). */
  .work__carousel {
    width: min(90vw, 1240px); /* a little wider */
  }

  .carousel__stage {
    position: relative;
    z-index: 3;
    width: 100%;
    min-height: clamp(400px, 47vw, 675px); /* ~25% taller */
  }

  /* ── the card ──────────────────────────────────────────── */
  .work__card {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: clamp(400px, 47vw, 675px); /* ~25% taller */
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    border: 3px solid var(--c-black);
    border-radius: 12px;
    overflow: hidden;
    /* transparent so the info pane's frosted glass can reveal the blurred
       landscape/section behind the card (z1/z2 sit under this card at z3).
       The header + preview panes paint their own opaque backgrounds. */
    background: transparent;
    box-shadow: 0 26px 55px rgba(0, 0, 0, 0.26);
    /* NOTE: do NOT set `will-change: transform`/`opacity` here. It promotes the
       card to a "backdrop root", which confines the info pane's backdrop-filter
       to sample *inside* the card (nothing) — silently killing the blur while
       still showing the scene through the transparent card. GSAP applies its own
       transforms during the slide and clears them on complete (clearProps), so
       the resting card has no transform and the frosted blur renders correctly. */
  }
  .work__card:not([data-active]) {
    opacity: 0;
    pointer-events: none;
  }

  .card__left {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .card__head {
    background: var(--c-black);
    padding: clamp(1.5rem, 4vw, 2.7rem) clamp(1rem, 2.4vw, 1.9rem); /* even taller title bar */
  }
  .card__wordmark {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.3rem, 6.2vw, 5.2rem);
    line-height: 0.86;
    color: var(--c-white);
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: clip;
  }
  .card__info {
    --info-pad: clamp(1.1rem, 2.4vw, 2rem);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(0.45rem, 1.3vw, 0.95rem);
    padding: var(--info-pad);
    /* frosted glass tinted with the project's accent (Dave-Holloway style).
       The accent sits at ~66% opacity: enough that the panel reads as its colour
       (purple for STC, red for Spartan, …) even over the green landscape behind
       the card, but transparent enough that the backdrop blur shows a soft,
       unrecognisable *feeling* of the scene behind — hazy light/dark shapes,
       never a sharp tree or hill. Tint opacity (not blur radius) is the lever for
       how much background shows; ~16px blur keeps the shapes dissolved. */
    background:
      linear-gradient(
        0deg,
        color-mix(in srgb, var(--accent, var(--c-black)) 66%, transparent),
        color-mix(in srgb, var(--accent, var(--c-black)) 66%, transparent)
      ),
      rgba(255, 255, 255, 0.05);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    backdrop-filter: blur(16px) saturate(150%);
    /* subtle glass edges: hairline outline + soft top highlight */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      inset 0 0 0 1px color-mix(in srgb, var(--accent, var(--c-black)) 30%, transparent);
  }
  /* no backdrop-filter support → solid accent tint so text stays readable and
     the panel never looks like an empty see-through hole */
  @supports not (
    (backdrop-filter: blur(2px)) or (-webkit-backdrop-filter: blur(2px))
  ) {
    .card__info {
      background: color-mix(in srgb, var(--accent, var(--c-black)) 78%, var(--c-white));
    }
  }
  .card__label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--c-black) 70%, transparent);
  }
  .card__client {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.4vw, 3.4rem);
    line-height: 0.92;
  }
  .card__role {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(0.8rem, 1.15vw, 0.95rem);
    color: color-mix(in srgb, var(--c-black) 62%, transparent);
  }
  /* tech line + tags = ONE entity: a full-width line (touches the card borders)
     with the downward triangles hanging directly off it. */
  .card__tags {
    margin-top: 0.6rem;
    margin-inline: calc(-1 * var(--info-pad));
    padding: 0 var(--info-pad);
    border-top: 2px solid var(--c-black);
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.9rem, 2.4vw, 2rem);
    list-style: none;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.07em;
  }
  .card__tags li {
    position: relative;
    padding-top: 0.95rem; /* room beneath the triangle for the label */
  }
  .card__tags li::before {
    content: "";
    position: absolute;
    top: 0; /* flat top flush against the line = one entity */
    left: 0;
    border: 6px solid transparent;
    border-top-color: var(--c-black); /* always black, regardless of accent */
  }
  .card__foot {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding-top: clamp(0.8rem, 2vw, 1.6rem);
  }
  .card__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 2px solid var(--c-black);
    border-radius: 0; /* squared at rest, like Dave's */
    padding: clamp(0.65rem, 1.5vw, 0.95rem) clamp(0.85rem, 1.7vw, 1.25rem);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.7vw, 1.4rem);
    text-decoration: none;
    color: var(--c-black);
  }
  .card__cta[aria-disabled="true"] { opacity: 0.4; pointer-events: none; }

  /* SAM-115 — hover: a directional "wave" of curvature. It bumps up on the LEFT
     corners, flows across to the RIGHT (echoing the left→right VIEW WORK curtain),
     then settles back to square. No colour change — the motion is the affordance. */
  @keyframes cta-wave {
    0% { border-radius: 0; }
    30% { border-radius: 22px 4px 4px 22px; } /* left corners bulge up */
    65% { border-radius: 4px 22px 22px 4px; } /* curvature flows to the right */
    100% { border-radius: 0; } /* settle back to square */
  }
  .card__cta:hover,
  .card__cta:focus-visible {
    animation: cta-wave 0.66s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card__arrow {
    border-left: 2px solid var(--c-black);
    padding-left: 0.8rem;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card__cta:hover .card__arrow,
  .card__cta:focus-visible .card__arrow { transform: translateX(4px); }

  @media (prefers-reduced-motion: reduce) {
    .card__cta:hover,
    .card__cta:focus-visible { animation: none; }
    .card__cta:hover .card__arrow,
    .card__cta:focus-visible .card__arrow { transform: none; }
  }
  .card__count {
    align-self: flex-end;
    font-family: var(--font-display);
    font-size: 0.95rem;
  }
  .card__count i { font-style: normal; opacity: 0.4; padding: 0 0.15em; }

  /* ── preview pane (image + shader canvas), full card height ─ */
  /* solid BLACK pane; the image is inset into it = a thick black frame with
     square inner corners and NO white gap. The card's rounding only clips the
     black pane's outer corners. */
  .card__preview {
    position: relative;
    overflow: hidden;
    background: var(--c-black);
  }
  .preview__img,
  .preview__canvas {
    position: absolute;
    top: 18px; /* thick top/right/bottom frame */
    left: 3px; /* thin divider, like the card border */
    width: calc(100% - 21px);
    height: calc(100% - 36px);
    display: block;
  }
  .preview__img { object-fit: cover; }
  .preview__canvas { opacity: 0; transition: opacity 0.22s ease; }
  .card__preview[data-shader-on] .preview__canvas { opacity: 1; }
  .card__preview[data-shader-on] .preview__img { opacity: 0; }
  .card__preview-mark {
    position: absolute;
    inset: 0;
    z-index: -1;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(2rem, 5vw, 4rem);
    color: var(--c-white);
    opacity: 0.4;
  }

  /* ── arrows: dark circles pinned to the screen edges ──── */
  /* big black CIRCLES that sit ~⅓ off the screen edges (like Dave's) */
  .carousel__arrow {
    --arrow-d: clamp(96px, 9vw, 132px);
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 6;
    width: var(--arrow-d);
    height: var(--arrow-d);
    border-radius: 50%;
    display: grid;
    place-items: center;
    border: none;
    background: var(--c-black);
    color: var(--c-white);
    cursor: pointer;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.32);
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .carousel__arrow svg {
    width: 34%;
    height: auto;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .carousel__arrow:hover { background: var(--c-gold); color: var(--c-black); }
  .carousel__arrow:active { transform: translateY(-50%) scale(0.94); }
  /* cut exactly at the center = true semicircle */
  .carousel__arrow--prev { left: calc(-0.5 * var(--arrow-d)); }
  .carousel__arrow--next { right: calc(-0.5 * var(--arrow-d)); }
  .carousel__arrow--prev svg { transform: translateX(calc(0.2 * var(--arrow-d))); } /* nudge glyph into the visible half */
  .carousel__arrow--next svg { transform: translateX(calc(-0.2 * var(--arrow-d))); }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  /* ── mobile ────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .work__carousel { width: min(92vw, 520px); }
    .carousel__stage { min-height: 600px; }
    /* vertical card: info on top, image pane on the bottom. Taller card → the image
       pane can be near-square (fits the square project renders better than a wide strip) */
    .work__card { grid-template-columns: 1fr; min-height: 600px; }

    /* info as a grid: label/client/role on the left, VIEW WORK beside the client on
       the right; tags full-width below; the 01/06 counter is dropped on mobile so the
       image below can be taller */
    .card__info {
      display: grid;
      grid-template-columns: 1fr auto;
      column-gap: 0.9rem;
      align-content: start;
    }
    .card__label,
    .card__client,
    .card__role { grid-column: 1; }
    .card__tags { grid-column: 1 / -1; }
    .card__foot {
      grid-column: 2;
      grid-row: 1 / 4;
      align-self: center;
      margin: 0;
      padding: 0;
    }
    .card__count { display: none; }

    /* the divider line crowds "VIEW WORK" on the narrow mobile button — drop it
       and let the arrow sit with a little breathing room instead */
    .card__arrow { border-left: none; padding-left: 0.55rem; }

    /* near-square image pane (fits the square renders better than a wide strip) */
    .card__preview { min-height: 340px; order: 2; }
    .preview__img,
    .preview__canvas {
      top: 3px;
      left: 3px;
      width: calc(100% - 6px);
      height: calc(100% - 6px);
    }
    /* compact the header so the taller image doesn't push the card past the viewport */
    .card__head { padding: clamp(1rem, 3vw, 1.7rem) clamp(1rem, 2.4vw, 1.9rem); }
    .card__wordmark { font-size: 12vw; }
    .carousel__arrow { --arrow-d: 80px; }
    .carousel__arrow--prev { left: calc(-0.5 * var(--arrow-d)); }
    .carousel__arrow--next { right: calc(-0.5 * var(--arrow-d)); }
  }
</style>

<script>
  import { initCarousel } from "../../scripts/carousel";
  initCarousel();
  // lazy-load the Three.js liquid-glass shader as its own chunk (skip if reduced-motion)
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    import("../../scripts/pixelDistortion")
      .then((m) => m.initShaders())
      .catch(() => {});
  }
</script>
