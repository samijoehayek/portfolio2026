---
// Interactive hero: a Rive scene (clouds + cursor-tracking character rig) fills
// the section; the glass "HEY" bio panel overlays on the left. The crypto-coin
// orbit is paused for now — it was anchored to the old DOM character and needs
// re-anchoring to the Rive head position.
const bio = {
  name: "Samijoe Hayek",
  role: "full-stack & blockchain developer and consultant",
  location: "Dubai, UAE",
};
---

<section class="hero" id="top" data-hero>
  <!-- Rive: clouds background + character (eyes/head track the cursor) -->
  <canvas class="hero__rive" data-rivecanvas aria-hidden="true"></canvas>
  <span class="sr-only">Cartoon illustration of {bio.name}</span>

  <!-- glass bio panel (left): two equal halves split by a dashed rule -->
  <div class="hero__panel">
    <div class="hero__panel-top">
      <h1 class="hero__title">HEY!</h1>
    </div>
    <div class="hero__panel-bottom">
      <p class="hero__bio">
        You've reached the portfolio of <strong>{bio.name}</strong> — a {bio.role}
        based in {bio.location}. Feel free to explore my work and a few of my
        favourite things.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: var(--c-blue);
    color: var(--c-black);
  }

  /* ── Rive scene canvas (clouds + character), full-bleed behind the panel ── */
  .hero__rive {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    display: block;
    pointer-events: none; /* cursor is read from the window, not via hit-testing */
  }

  /* ── glass bio panel ──────────────────────────────────── */
  .hero__panel {
    position: absolute;
    top: 60%;
    left: clamp(1rem, 5vw, 5rem);
    transform: translateY(-50%);
    width: clamp(320px, 42vw, 600px);
    min-height: clamp(290px, 42vh, 430px);
    z-index: 4;
    display: grid;
    grid-template-rows: 1fr 1fr; /* two equal halves */
    background: color-mix(in srgb, var(--c-white) 7%, transparent);
    backdrop-filter: blur(7px) saturate(112%);
    -webkit-backdrop-filter: blur(7px) saturate(112%);
    border: var(--border);
    border-radius: 8px;
    overflow: hidden;
    color: var(--c-black);
  }
  .hero__panel-top,
  .hero__panel-bottom {
    display: grid;
    align-items: center;
    padding: clamp(0.85rem, 2.2vw, 1.7rem);
  }
  /* full-width dashed rule sits exactly between the two equal halves */
  .hero__panel-bottom {
    border-top: 2px dashed var(--c-black);
  }
  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.82;
    letter-spacing: 0.02em;
    /* stretch the wordmark to nearly fill the width of its half (no extra height) */
    transform: scaleX(1.42);
    transform-origin: left center;
  }
  .hero__bio {
    font-size: clamp(0.95rem, 1.3vw, 1.2rem);
    line-height: 1.5;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  /* ── mobile: panel drops to the bottom over the scene ─────── */
  @media (max-width: 860px) {
    .hero__panel {
      top: auto;
      bottom: clamp(1.5rem, 6vw, 3rem);
      left: 50%;
      transform: translateX(-50%);
      width: min(92vw, 460px);
    }
  }
</style>

<script>
  import { initHero } from "../scripts/hero";

  let cleanup: (() => void) | void;
  const boot = () => { cleanup?.(); cleanup = initHero(); };

  boot(); // initial load
  // View Transitions (ClientRouter): dispose the Rive/WASM instance on swap,
  // re-boot after the new DOM is in place — prevents leaks across navigations.
  document.addEventListener("astro:before-swap", () => cleanup?.());
  document.addEventListener("astro:after-swap", boot);
</script>
