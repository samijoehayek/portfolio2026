---
// Interactive hero: a Rive scene (clouds + cursor-tracking character rig) fills
// the section; the glass "HEY" bio panel overlays on the left. The crypto-coin
// orbit is paused for now — it was anchored to the old DOM character and needs
// re-anchoring to the Rive head position.
const bio = {
  name: "Samijoe Hayek",
  role: "full-stack & blockchain developer and consultant",
  location: "Dubai, UAE",
};
---

<section class="hero" id="top" data-hero>
  <!-- Rive: clouds background + character (eyes/head track the cursor).
       The wrap is display:contents on desktop (no effect) and becomes a
       portrait crop-frame on mobile so the character reads big + centred. -->
  <div class="hero__rive-wrap" aria-hidden="true">
    <canvas class="hero__rive" data-rivecanvas></canvas>
  </div>
  <span class="sr-only">Cartoon illustration of {bio.name}</span>

  <!-- glass bio panel (left): two equal halves split by a dashed rule -->
  <div class="hero__panel">
    <div class="hero__panel-top">
      <h1 class="hero__title">HEY!</h1>
    </div>
    <div class="hero__panel-bottom">
      <p class="hero__bio">
        You've reached the portfolio of <strong>{bio.name}</strong> — a {bio.role}
        based in {bio.location}. Feel free to explore my work and a few of my
        favourite things.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: var(--c-blue);
    color: var(--c-black);
  }

  /* ── Rive scene canvas (clouds + character), full-bleed behind the panel ── */
  .hero__rive-wrap {
    display: contents; /* desktop: no box — canvas positions against .hero */
  }
  .hero__rive {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    display: block;
    pointer-events: none; /* cursor is read from the window, not via hit-testing */
  }

  /* ── glass bio panel ──────────────────────────────────── */
  .hero__panel {
    position: absolute;
    top: 60%;
    left: clamp(1.5rem, 6.5vw, 6.5rem);
    transform: translateY(-50%);
    width: clamp(320px, 42vw, 600px);
    z-index: 4;
    /* one inset value drives top/left/bottom of EACH section and the gap
       between them — so every spacing in the panel is the same */
    --pad: clamp(1.4rem, 3.2vw, 2.6rem);
    display: grid;
    grid-template-rows: auto auto; /* panel hugs its content, no extra height */
    background: color-mix(in srgb, var(--c-white) 7%, transparent);
    backdrop-filter: blur(7px) saturate(112%);
    -webkit-backdrop-filter: blur(7px) saturate(112%);
    border: var(--border);
    border-radius: 8px;
    overflow: hidden;
    color: var(--c-black);
  }
  .hero__panel-top,
  .hero__panel-bottom {
    padding: var(--pad); /* equal inset on all four sides */
  }
  /* full-width dashed rule sits exactly between the two equal halves */
  .hero__panel-bottom {
    border-top: 2px dashed var(--c-black);
  }
  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(4.3rem, 12.8vw, 9.6rem);
    line-height: 0.82;
    letter-spacing: 0.02em;
    /* stretch the wordmark to nearly fill the width of its half (no extra height) */
    transform: scaleX(1.34);
    transform-origin: left center;
  }
  .hero__bio {
    font-size: clamp(1.02rem, 1.4vw, 1.3rem);
    line-height: 1.5;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  /* ── mobile: stop overlaying — stack a big, centred character above one
     flush, full-width, centred HEY + bio block (thin seam, no inner rule) ── */
  @media (max-width: 860px) {
    .hero {
      display: flex;
      flex-direction: column;
      min-height: auto;
      padding-top: var(--header-h); /* clear the fixed header */
    }

    /* the wrap becomes a portrait crop-frame; the canvas keeps the full 16:9
       scene but is scaled up and slid left so the (right-of-centre) character
       reads BIG and centred, with the empty clouds cropped away */
    .hero__rive-wrap {
      display: block;
      position: relative;
      width: 100%;
      aspect-ratio: 4 / 5;
      overflow: hidden;
    }
    .hero__rive {
      inset: auto;
      top: 0;
      left: 50%;
      width: auto;
      height: 100%;
      aspect-ratio: 1920 / 1080; /* full hero-rive-SVG scene, no internal crop */
      transform: translateX(-72%); /* slide the character to frame centre */
    }

    /* glass box → one flush, centred, full-width section under the scene */
    .hero__panel {
      position: static;
      transform: none;
      top: auto;
      left: auto;
      width: 100%;
      background: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      border-top: 1px solid var(--c-black); /* thin seam under the scene */
      border-radius: 0;
      text-align: center;
    }
    /* no inner divider now that HEY + bio are a single centred section */
    .hero__panel-bottom {
      border-top: none;
    }
    .hero__title {
      text-align: center;
      transform-origin: center center;
    }
    .hero__bio {
      text-align: center;
    }
  }
</style>

<script>
  import { initHero } from "../scripts/hero";

  let cleanup: (() => void) | void;
  const boot = () => { cleanup?.(); cleanup = initHero(); };

  boot(); // initial load
  // View Transitions (ClientRouter): dispose the Rive/WASM instance on swap,
  // re-boot after the new DOM is in place — prevents leaks across navigations.
  document.addEventListener("astro:before-swap", () => cleanup?.());
  document.addEventListener("astro:after-swap", boot);
</script>
