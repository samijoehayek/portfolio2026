---
// Interactive hero: layered illustration (clouds + character + coins) that
// reacts to the cursor — eyes track, head tilts, blinks, clouds & coins drift.
// Built from the cut PNG layers in /public/hero/*.webp.
const bio = {
  name: "Samijoe Hayek",
  role: "full-stack & blockchain developer and consultant",
  location: "Dubai, UAE",
};
---

<section class="hero" id="top" data-hero>
  <!-- sky / clouds background (full-bleed, drifts + parallax) -->
  <div class="hero__sky" data-sky aria-hidden="true">
    <img class="hero__clouds" src="/hero/clouds.webp" alt="" decoding="async" />
  </div>

  <!-- 3D crypto-coin orbit (ETH / BTC / SOL circle the head) -->
  <canvas class="hero__coincanvas" data-coincanvas aria-hidden="true"></canvas>

  <!-- character (right) -->
  <div class="hero__character" data-character>
    <div class="char" data-char>
      <img class="char__layer" src="/hero/body.webp" alt="" decoding="async" />
      <div class="char__head" data-head>
        <img class="char__layer" src="/hero/head-base.webp" alt="" decoding="async" />
        <img class="char__layer" src="/hero/eye-whites.webp" alt="" decoding="async" />
        <!-- pupils clipped to the eye-white shape so they can never leave the socket -->
        <div class="char__layer char__eyeclip">
          <img class="char__pupils" src="/hero/pupils.webp" alt="" data-pupils decoding="async" />
        </div>
        <img class="char__layer char__eyelids" src="/hero/eyelids.webp" alt="" data-eyelids decoding="async" />
      </div>
    </div>
    <span class="sr-only">Cartoon illustration of {bio.name}</span>
  </div>

  <!-- glass bio panel (left): two equal halves split by a dashed rule -->
  <div class="hero__panel">
    <div class="hero__panel-top">
      <h1 class="hero__title">HEY!</h1>
    </div>
    <div class="hero__panel-bottom">
      <p class="hero__bio">
        You've reached the portfolio of <strong>{bio.name}</strong> — a {bio.role}
        based in {bio.location}. Feel free to explore my work and a few of my
        favourite things.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: var(--c-blue);
    color: var(--c-black);
  }

  /* ── sky / clouds ─────────────────────────────────────── */
  .hero__sky {
    position: absolute;
    inset: -3.5% -3.5% -3.5% -3.5%; /* slight oversize for drift/parallax room */
    z-index: 1;
    translate: var(--cx, 0) var(--cy, 0); /* JS parallax (independent of drift) */
  }
  .hero__clouds {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: cloudDrift 55s ease-in-out infinite; /* uses transform */
  }
  @keyframes cloudDrift {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-3%); }
  }

  /* ── coin orbit canvas (sits ABOVE the character so coins can pass in
     front; an in-scene depth occluder makes them vanish behind the head) ── */
  .hero__coincanvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    pointer-events: none;
    display: block;
  }

  /* ── character ────────────────────────────────────────── */
  .hero__character {
    position: absolute;
    bottom: 0;
    right: clamp(0px, 2vw, 70px);
    height: clamp(440px, 90vh, 1000px);
    aspect-ratio: 896 / 1200;
    z-index: 3;
  }
  /* soft contact shadow grounding the character */
  .hero__character::after {
    content: "";
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: 2%;
    height: 6%;
    background: radial-gradient(50% 100% at 50% 100%, rgba(0, 0, 0, 0.22), transparent 72%);
    z-index: -1;
    pointer-events: none;
  }
  .char,
  .char__head {
    position: absolute;
    inset: 0;
  }
  /* gentle idle breathing — head rides along since it's nested inside .char */
  .char {
    translate: var(--bodyx, 0) var(--bodyy, 0); /* JS body parallax (2.5D) */
    animation: breathe 4.2s ease-in-out infinite;
    will-change: transform, translate;
  }
  @keyframes breathe {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-0.55%) scale(1.006); }
  }
  .char__layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  /* head group: very subtle tilt, pivoting low at the neck so the neck
     cut never opens a gap (set by JS) */
  .char__head {
    transform: translate(var(--hx, 0), var(--hy, 0)) rotate(var(--hr, 0deg));
    transform-origin: 50% 92%;
    will-change: transform;
  }
  /* eye socket clip: masks the pupils to the eye-white shape, so the pupils
     stay inside the eyes no matter how far they track */
  .char__eyeclip {
    -webkit-mask: url("/hero/eye-whites.webp") center / 100% 100% no-repeat;
    mask: url("/hero/eye-whites.webp") center / 100% 100% no-repeat;
  }
  .char__pupils {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform: translate(var(--px, 0), var(--py, 0));
    will-change: transform;
  }
  /* eyelids: hidden at rest; blink = a quick, crisp close */
  .char__eyelids {
    opacity: 0;
    transition: opacity 45ms ease;
  }
  .char__eyelids.is-closed { opacity: 1; }

  /* ── glass bio panel ──────────────────────────────────── */
  .hero__panel {
    position: absolute;
    top: 60%;
    left: clamp(1rem, 5vw, 5rem);
    transform: translateY(-50%);
    width: clamp(320px, 42vw, 600px);
    min-height: clamp(290px, 42vh, 430px);
    z-index: 4;
    display: grid;
    grid-template-rows: 1fr 1fr; /* two equal halves */
    background: color-mix(in srgb, var(--c-white) 7%, transparent);
    backdrop-filter: blur(7px) saturate(112%);
    -webkit-backdrop-filter: blur(7px) saturate(112%);
    border: var(--border);
    border-radius: 8px;
    overflow: hidden;
    color: var(--c-black);
  }
  .hero__panel-top,
  .hero__panel-bottom {
    display: grid;
    align-items: center;
    padding: clamp(0.85rem, 2.2vw, 1.7rem);
  }
  /* full-width dashed rule sits exactly between the two equal halves */
  .hero__panel-bottom {
    border-top: 2px dashed var(--c-black);
  }
  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.82;
    letter-spacing: 0.02em;
    /* stretch the wordmark to nearly fill the width of its half (no extra height) */
    transform: scaleX(1.42);
    transform-origin: left center;
  }
  .hero__bio {
    font-size: clamp(0.95rem, 1.3vw, 1.2rem);
    line-height: 1.5;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  /* ── mobile: stack panel over a smaller character ─────── */
  @media (max-width: 860px) {
    .hero__character {
      height: 62vh;
      right: 50%;
      transform: translateX(50%);
      opacity: 0.9;
    }
    .hero__panel {
      top: auto;
      bottom: clamp(1.5rem, 6vw, 3rem);
      left: 50%;
      transform: translateX(-50%);
      width: min(92vw, 460px);
    }
    .backdrop-filter { backdrop-filter: blur(10px); }
  }
</style>

<script>
  import { initHero } from "../scripts/hero";
  initHero();
</script>
