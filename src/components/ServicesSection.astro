---
// Services section — the "laundry line": cards hang from a cord that threads through
// each card's eyelet. The cord runs BEHIND a card from its left edge to the eyelet,
// then IN FRONT from the eyelet to the right edge (and shows in the gaps) — so it
// reads as a real string threaded through holes. Cards swing like washing as you
// grab-and-fling the row. Motion lives in src/scripts/servicesLine.ts.
import { services } from "../data/services";

const titleChars = "SERVICES".split("");
---

<section class="services" id="services" data-services aria-label="Services">
  <header class="services__header">
    <h2 class="services__title" aria-label="Services">
      {
        titleChars.map((ch, i) => (
          <span class="services__title-char" style={`--i:${i}`} aria-hidden="true">
            {ch}
          </span>
        ))
      }
    </h2>
    <div class="services__intro">
      <p class="services__intro-text">
        Full-stack across blockchain, back-end and front-end — I take a project
        from ground zero to a production launch.
      </p>
      <a class="services__cta" href="#about">get in touch &rarr;</a>
    </div>
  </header>

  <div class="services__scroller" data-scroller>
    <!-- THE TRACK: flex row moved only via transform:translateX -->
    <ul class="services__track" data-track role="list">
      <!-- BACK CORD: one bar behind every card (shows in gaps + behind each card's left half) -->
      <div class="services__cord services__cord--back" data-cable aria-hidden="true"></div>

      {
        services.map((s) => (
          <li class="service-card" data-card style={`--accent-raw:${s.accent}`}>
            <div class="service-card__inner" data-inner tabindex="0" aria-label={s.name}>
              <!-- ONE rounded card: tall black panel (with the clip INSIDE) + glassy body -->
              <div class="service-card__card">
                <div class="service-card__top">
                  <!-- the clip lives INSIDE the black panel; the cord threads its eyelet -->
                  <div class="service-card__clip">
                    <span class="service-card__code">{s.code}</span>
                    <span class="service-card__eyelet" aria-hidden="true" />
                    <span class="service-card__date">{s.date}</span>
                  </div>
                  <span class="service-card__monogram" aria-hidden="true">{s.code}</span>
                </div>

                <div class="service-card__body">
                  <span class="service-card__label">Service</span>
                  <h3 class="service-card__name">{s.name}</h3>

                  <!-- markers timeline: thick line, triangles above & below -->
                  <div class="service-card__markers">
                    <div class="service-card__markers-row">
                      {s.markers.map((m, i) => (
                        <div
                          class={`service-card__marker service-card__marker--${i % 2 === 0 ? "up" : "down"}`}
                        >
                          <span class="service-card__marker-tri" aria-hidden="true" />
                          <span class="service-card__marker-label">{m}</span>
                        </div>
                      ))}
                    </div>
                  </div>

                  <span class="service-card__divider" aria-hidden="true" />

                  <!-- outline word-cycle -->
                  <div class="service-card__journey" aria-hidden="true">
                    <span class="word">{s.journey[0]}</span>
                    <span class="arrow">&rarr;</span>
                    <span class="word">{s.journey[1]}</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- FRONT CORD: eyelet → right edge, OUTSIDE the swinging inner so it stays straight -->
            <div class="services__cord services__cord--front" aria-hidden="true"></div>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- mobile-only affordance: tells the user the row of cards is draggable -->
  <p class="services__swipe-hint" aria-hidden="true">
    <span class="services__swipe-arrow">&harr;</span> drag the line
  </p>

  <span class="sr-only">What I do.</span>
</section>

<style>
  .services {
    /* the clip is a fluid square; the eyelet is grid-centred inside it (see
       .service-card__clip), so its centre is ALWAYS --clip-top + --clip-size/2.
       Deriving --eye from the same vars locks the cord to the hole at every
       width (previously --eye was a hardcoded 90px while the eyelet scaled with
       vw → the cord drifted below the hole as the screen narrowed). */
    --clip-top: 8px;
    --clip-size: clamp(114px, 13vw, 140px);
    /* eyelet centre from the card's top edge = card border + clip top + half the
       clip (the eyelet is grid-centred in the clip). The cord lives on .service-card
       (outside the bordered card), so it must include the border to line up. */
    --eye: calc(var(--bw) + var(--clip-top) + var(--clip-size) / 2); /* cord = eyelet centre */
    --cord-h: 14px;
    --gap: clamp(2rem, 3.4vw, 3.8rem); /* gap between cards (also used by the front cord) */
    position: relative;
    min-height: 138vh;
    overflow: hidden;
    background: var(--c-blue);
    color: var(--c-black);
    border-top: var(--border); /* same divider as the navbar / Work */
    padding: clamp(4rem, 9vh, 7rem) 0 clamp(3.5rem, 9vh, 7rem);
    display: flex;
    flex-direction: column;
  }

  /* ── header ─────────────────────────────────────────────── */
  .services__header {
    display: grid;
    grid-template-columns: 1fr minmax(0, 27rem);
    align-items: end;
    gap: 1.5rem 2rem;
    padding: 0 var(--gutter);
  }
  .services__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(4rem, 16vw, 15rem);
    line-height: 0.78;
    letter-spacing: 0.01em;
    color: var(--c-black);
  }
  .services__title-char {
    display: inline-block;
    will-change: transform, opacity;
  }
  .services__intro {
    margin: 0 0 0.6rem;
  }
  .services__intro-text {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(0.95rem, 1.15vw, 1.15rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--c-black) 86%, transparent);
  }
  .services__cta {
    display: inline-block;
    margin-top: 0.9rem;
    font-family: var(--font-nav);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    color: var(--c-black);
    text-decoration: none;
    border-bottom: var(--bw) solid var(--c-black);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .services__cta:hover {
    color: var(--c-gold);
    border-color: var(--c-gold);
  }

  /* ── scroller ───────────────────────────────────────────── */
  .services__scroller {
    position: relative;
    margin-top: clamp(2rem, 5vh, 4rem);
    flex: 1;
    padding-top: 44px; /* a little blue above the cards */
    overflow: visible;
    cursor: grab;
  }
  .services__scroller:active {
    cursor: grabbing;
  }

  /* ── track ──────────────────────────────────────────────── */
  .services__track {
    list-style: none;
    margin: 0;
    padding: 0 clamp(1.5rem, 5vw, 5rem); /* first/last card not flush to the edge */
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--gap);
    width: max-content;
    will-change: transform;
    position: relative;
    z-index: 2;
    touch-action: pan-y; /* let Lenis keep vertical scroll; we own horizontal */
  }

  /* the metal rod: dark at bottom, mid-grey body, bright highlight on the top edge */
  .services__cord {
    height: var(--cord-h);
    background: linear-gradient(0deg, #000, #333 22%, #555 55%, #aaa 88%, #ddd);
    pointer-events: none;
  }
  /* faint backing bar — only ever seen in the leading gap before the first card
     (everywhere else it's hidden behind a card or under a front bar). No shadow,
     so it can't seam against the front bars. */
  .services__cord--back {
    position: absolute;
    top: calc(var(--eye) - var(--cord-h) / 2);
    left: 0;
    right: 0;
    z-index: 0;
  }
  /* THE visible cord: ONE continuous piece per card — from the eyelet's left edge,
     through the hole, across the card's right half and the gap, tucking behind the
     next card. Outside the swinging inner, so it stays perfectly straight. */
  .services__cord--front {
    position: absolute;
    top: calc(var(--eye) - var(--cord-h) / 2);
    left: 50%; /* from the eyelet centre to the card's right edge (gaps = the back cord) */
    right: 0;
    z-index: 2; /* on top of the card; the in-hole cord band lives in the eyelet itself */
  }

  .service-card {
    --body-px: clamp(1.3rem, 2.4vw, 2rem); /* body side padding (reused by the full-bleed divider) */
    /* mute the raw accent a touch (mix ~14% neutral grey) so the card colours
       read slightly softer/more refined — subtle, not bland. One lever feeds the
       monogram, clip, glass body + glow. */
    --accent: color-mix(in srgb, var(--accent-raw) 86%, #808080);
    position: relative;
    z-index: 1; /* above the back cord */
    flex: 0 0 auto;
    width: clamp(384px, 40vw, 600px);
    list-style: none;
  }

  /* THE SWINGING BODY — pivots from the cord/eyelet line */
  .service-card__inner {
    position: relative;
    transform-origin: 50% var(--eye); /* the eyelet — the pendulum pivot */
    will-change: transform;
    outline: none;
  }
  .service-card__inner:focus-visible {
    outline: var(--bw) solid var(--c-gold);
    outline-offset: 6px;
  }

  /* ── ONE rounded card ───────────────────────────────────── */
  .service-card__card {
    width: 100%;
    border: var(--bw) solid #0a0a0a;
    border-radius: 40px; /* a little more rounded */
    overflow: hidden;
    background: var(--c-black);
  }
  .service-card__top {
    position: relative;
    background: var(--c-black);
    height: clamp(250px, 30vh, 366px); /* shorter than the body, trimmed from the bottom */
    display: flex;
    align-items: center;
    justify-content: flex-start; /* monogram sits to the LEFT */
    padding: 154px 0 0 clamp(1.8rem, 3.2vw, 3rem); /* clear the square clip; left inset */
  }
  .service-card__monogram {
    font-family: var(--font-display);
    font-size: clamp(4.4rem, 9.4vw, 8.4rem); /* a touch shorter */
    line-height: 0.8;
    letter-spacing: 0.02em;
    color: var(--accent);
  }

  /* ── the clip / tag (INSIDE the black panel), eyelet threaded by the cord ─ */
  .service-card__clip {
    position: absolute;
    top: var(--clip-top);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1; /* over the card's black, under the front cord */
    width: var(--clip-size);
    aspect-ratio: 1; /* square */
    background: var(--accent);
    border: var(--bw) solid #0a0a0a;
    border-radius: 12px;
    /* 1fr · auto · 1fr grid → the eyelet (middle, auto) is centred in the square
       REGARDLESS of the code/date text sizes, so its centre == the clip centre
       == --eye. This is what keeps the cord threaded at every viewport width. */
    display: grid;
    grid-template-rows: 1fr auto 1fr;
    place-items: center; /* centre code · eyelet · date each in their band */
    box-shadow: 0 8px 0 -4px rgba(0, 0, 0, 0.22);
  }
  .service-card__code {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    line-height: 1;
    color: #0a0a0a;
  }
  /* the eyelet: just a blue-filled ring that sits BEHIND the cord. The single front
     bar crosses its middle, so the blue shows above/below = a real open hole, and the
     cord stays one continuous piece (no stub to seam against). */
  /* the grommet: blue hole with a dark ring + the cord band drawn INSIDE it (the cord seen
     through the hole). The front cord segment continues it from the centre to the right. */
  .service-card__eyelet {
    position: relative;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: var(--bw) solid #0a0a0a;
    background: var(--c-blue);
    overflow: hidden;
  }
  .service-card__eyelet::before {
    content: "";
    position: absolute;
    left: -5px;
    right: -5px;
    top: 50%;
    transform: translateY(-50%);
    height: var(--cord-h);
    background: linear-gradient(0deg, #000, #333 22%, #555 55%, #aaa 88%, #ddd);
  }
  .service-card__date {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.55rem;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, #0a0a0a 72%, transparent);
  }

  /* ── glassy translucent body ────────────────────────────── */
  .service-card__body {
    position: relative;
    isolation: isolate;
    overflow: hidden; /* clip the blurred glow blob to the body */
    display: flex;
    flex-direction: column;
    border-top: var(--bw) solid #0a0a0a;
    padding: clamp(2rem, 3.6vw, 3rem) var(--body-px) clamp(1.9rem, 3.2vw, 2.6rem);
    /* frosted glass: translucent accent over the card's black + a hairline top
       sheen. A real backdrop-filter of the section CAN'T work here — the card
       lives inside a transformed/dragged track (a backdrop-root), the same
       mechanic documented on SAM-7 — so the frost is built INSIDE the card via a
       blurred accent glow (::before) instead. Matches the Work glass at a glance. */
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--accent) 74%, transparent),
      color-mix(in srgb, var(--accent) 44%, transparent)
    );
    box-shadow: inset 0 1px 0 color-mix(in srgb, #fff 42%, transparent);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    backdrop-filter: blur(16px) saturate(140%);
  }
  /* the frost: a soft, heavily-blurred light+accent glow that gives the body
     glassy depth without depending on a live backdrop */
  .service-card__body::before {
    content: "";
    position: absolute;
    inset: -30%;
    z-index: -1;
    background:
      radial-gradient(
        45% 55% at 18% 12%,
        color-mix(in srgb, #fff 55%, transparent),
        transparent 70%
      ),
      radial-gradient(
        55% 60% at 88% 108%,
        color-mix(in srgb, var(--accent) 96%, #fff),
        transparent 72%
      );
    filter: blur(26px);
    opacity: 0.55;
    pointer-events: none;
  }
  .service-card__label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, #0a0a0a 60%, transparent);
  }
  .service-card__name {
    margin: 0.35rem 0 0; /* tight under the SERVICE label */
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.4vw, 2.8rem);
    line-height: 0.94;
    letter-spacing: 0.01em;
    color: #0a0a0a;
  }

  /* ── markers timeline (thick line + triangles sitting on it) ─ */
  .service-card__markers {
    --half: 70px;
    position: relative;
    height: 140px;
    /* full-bleed: negate the body padding so the black tech line touches the card
       edge-to-edge on every card size (matches the divider below it) */
    margin: clamp(2rem, 3.6vw, 3.1rem) calc(-1 * var(--body-px)) 0;
  }
  .service-card__markers::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 4px; /* thicker than the card outline */
    background: #0a0a0a;
  }
  .service-card__markers-row {
    position: relative;
    height: 100%;
    display: flex;
    padding-inline: var(--body-px); /* keep the triangles/labels off the very edge */
  }
  .service-card__marker {
    flex: 1 1 0;
    min-width: 0;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .service-card__marker--up {
    flex-direction: column-reverse;
    justify-content: flex-start; /* column-reverse inverts this → packs DOWN to the line */
    padding-bottom: var(--half);
  }
  .service-card__marker--down {
    flex-direction: column;
    justify-content: flex-start;
    padding-top: var(--half);
  }
  .service-card__marker-tri {
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
  }
  .service-card__marker--up .service-card__marker-tri {
    border-bottom: 9px solid #0a0a0a; /* ▲ points up, base sitting ON the line */
  }
  .service-card__marker--down .service-card__marker-tri {
    border-top: 9px solid #0a0a0a; /* ▼ points down, base sitting ON the line */
  }
  .service-card__marker-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.01em;
    color: #0a0a0a;
    text-align: center;
    white-space: nowrap;
  }

  .service-card__divider {
    display: block;
    height: 3px;
    /* full-bleed: negate the body padding so it touches the card edge to edge */
    margin: clamp(1.2rem, 2.4vw, 1.9rem) calc(-1 * var(--body-px)) clamp(1.2rem, 2.4vw, 1.9rem);
    /* finer, more frequent dashes (6px dash / 6px gap) */
    background-image: repeating-linear-gradient(
      to right,
      color-mix(in srgb, #0a0a0a 55%, transparent) 0 6px,
      transparent 6px 12px
    );
    background-repeat: repeat-x;
    background-size: 100% 3px;
    background-position: 0 50%;
  }

  /* ── outline word-cycle ─────────────────────────────────── */
  .service-card__journey {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.8vw, 3.5rem);
    line-height: 1;
  }
  .service-card__journey .word {
    color: transparent;
    -webkit-text-stroke: 2px #0a0a0a;
    transition: color 0.4s ease;
  }
  .service-card__journey .word.is-lit {
    color: #0a0a0a;
    -webkit-text-stroke: 2px #0a0a0a;
  }
  .service-card__journey .arrow {
    color: #0a0a0a;
    font-family: var(--font-sans);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── mobile swipe affordance (shown only ≤860px) ─────────── */
  .services__swipe-hint {
    display: none; /* desktop: hidden (mouse users grab-and-fling) */
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    margin: 1.4rem var(--gutter) 0;
    font-family: var(--font-nav);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--c-black) 66%, transparent);
  }
  .services__swipe-arrow {
    display: inline-block;
    font-size: 1.15rem;
    animation: services-swipe-nudge 1.5s ease-in-out infinite;
  }
  @keyframes services-swipe-nudge {
    0%, 100% { transform: translateX(-4px); }
    50% { transform: translateX(4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .services__swipe-arrow { animation: none; }
  }

  /* ── entrance reveal (JS adds .reveal-ready, then .is-in) ── */
  .services.reveal-ready .services__title-char {
    opacity: 0;
    transform: translateY(60%) rotate(6deg);
    transition:
      opacity 0.6s ease calc(var(--i) * 0.045s),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i) * 0.045s);
  }
  .services.reveal-ready .services__scroller {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.9s ease 0.3s,
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
  }
  .services.reveal-ready.is-in .services__title-char {
    opacity: 1;
    transform: translateY(0) rotate(0);
  }
  .services.reveal-ready.is-in .services__scroller {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── mobile ─────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .services__header {
      grid-template-columns: 1fr;
    }
    /* tighter gap + narrower cards so the NEXT card always peeks in at the right
       edge — the universal "there's more, swipe me" cue. Combined with the JS
       snap, each swipe lands one card cleanly. */
    .services {
      --gap: 1.3rem;
    }
    .service-card {
      width: clamp(258px, 78vw, 360px);
    }
    .services__track {
      padding-inline: 1.15rem; /* first card near the edge, cord reads across */
    }
    .services__swipe-hint {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services__scroller {
      overflow-x: auto;
      cursor: default;
    }
  }
</style>

<script>
  import { initServicesLine } from "../scripts/servicesLine";

  const section = document.querySelector<HTMLElement>("[data-services]");
  if (section) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduce) {
      section.classList.add("reveal-ready");
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0]?.isIntersecting) {
            section.classList.add("is-in");
            io.disconnect();
          }
        },
        { threshold: 0.12 },
      );
      io.observe(section);
    }
  }

  initServicesLine();
</script>
