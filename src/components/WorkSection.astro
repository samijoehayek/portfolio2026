---
// Work section — the project CARD CAROUSEL sits inside the hillside/biker scene.
// The card stays at z3 (between the back hills z1/z2 and the front hill z4 + biker z5),
// so it reads as "tucked into the hillside". Carousel + shader live in ProjectCarousel.
import ProjectCarousel from "./work/ProjectCarousel.astro";
---

<section class="work" id="work" data-work aria-label="Selected work">
  <!-- giant WORK wordmark, partly hidden behind the card -->
  <span class="work__word" aria-hidden="true">WORK</span>

  <!-- layered rolling-hills backdrop (BEHIND the card) -->
  <div class="work__back" aria-hidden="true">
    <img src="/work-assets/hills-back-v2.svg" alt="" decoding="async" />
  </div>

  <!-- the project card carousel (6 stacked cards + arrows + markers + shader) -->
  <ProjectCarousel />

  <!-- foreground hillside (road/hill/wall) — sits IN FRONT of the card -->
  <div class="work__front" aria-hidden="true">
    <img src="/work-assets/foreground.svg" alt="" decoding="async" />
  </div>

  <!-- animated cyclist (Rive): drinks + breathes — small, on the road at the right -->
  <div class="work__biker" aria-hidden="true">
    <canvas class="work__biker-canvas" data-cyclist></canvas>
  </div>
  <span class="sr-only">Selected work.</span>
</section>

<style>
  .work {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: var(--c-blue);
    color: var(--c-black);
    display: grid;
    place-items: center;
    /* same divider as the navbar between sections */
    border-top: var(--border);
  }

  /* ── rolling-hills backdrop (behind the card) ──────────── */
  .work__back {
    position: absolute;
    left: 50%;
    bottom: 0;
    /* full-bleed width so the whole hill scene fits horizontally; the art is
       a wide-short hill band (2688×1125), so 100% width keeps height modest */
    width: 100%;
    transform: translateX(-50%);
    z-index: 1;
    pointer-events: none;
  }
  .work__back img {
    width: 100%;
    height: auto;
    display: block;
    transform-origin: bottom center;
    /* SAM-21: subtle always-on idle drift — alive but calm. The slight scale gives
       overscan room so the drift never reveals an edge; .work overflow:hidden clips it. */
    animation: workBackDrift 24s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes workBackDrift {
    from { transform: scale(1.045) translate(-0.7%, 0); }
    to   { transform: scale(1.045) translate(0.8%, -0.7%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .work__back img { animation: none; transform: none; }
  }

  /* ── foreground hillside (in FRONT of the card) ────────── */
  .work__front {
    position: absolute;
    right: 0;
    bottom: 0;
    width: min(66vw, 1000px);
    z-index: 4; /* above the card (z3) = card sits inside the hill */
    pointer-events: none;
  }
  .work__front img { width: 100%; height: auto; display: block; }

  /* ── animated cyclist (Rive) — small, on the road at the right ─────────── */
  .work__biker {
    position: absolute;
    right: 22%;
    bottom: 6%;
    height: clamp(235px, 39vh, 480px);
    aspect-ratio: 1360 / 2048; /* cyclist rig portrait; Fit.Contain letterboxes the rest */
    z-index: 5; /* on top of the foreground hill/road (z4) */
    pointer-events: none;
  }
  .work__biker-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── giant WORK wordmark ───────────────────────────────── */
  .work__word {
    position: absolute;
    top: 16%;
    right: clamp(2rem, 8vw, 11rem);
    transform: translateY(-50%);
    z-index: 2;
    font-family: var(--font-display);
    font-size: clamp(5rem, 17vw, 16rem);
    line-height: 0.8;
    letter-spacing: 0.05em; /* looser tracking reads a touch lighter */
    color: color-mix(in srgb, var(--c-white) 90%, transparent);
    user-select: none;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  /* ── entrance reveal (JS adds .reveal-ready, then .is-in on scroll) ── */
  .work.reveal-ready .work__back,
  .work.reveal-ready .work__word,
  .work.reveal-ready :global(.carousel__stage) {
    opacity: 0;
  }
  .work.reveal-ready .work__back {
    transform: translateX(-50%) translateY(24px);
    transition: opacity 0.9s ease 0.05s,
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.05s;
  }
  .work.reveal-ready .work__word {
    transform: translateY(-50%) translateX(54px);
    transition: opacity 0.8s ease 0.18s,
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.18s;
  }
  .work.reveal-ready :global(.carousel__stage) {
    transform: translateY(48px) scale(0.97);
    transition: opacity 0.9s ease 0.28s,
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.28s;
  }
  .work.reveal-ready.is-in .work__back { opacity: 1; transform: translateX(-50%) translateY(0); }
  .work.reveal-ready.is-in .work__word { opacity: 1; transform: translateY(-50%) translateX(0); }
  .work.reveal-ready.is-in :global(.carousel__stage) { opacity: 1; transform: translateY(0) scale(1); }

  /* ── mobile ────────────────────────────────────────────── */
  @media (max-width: 860px) {
    /* WORK wordmark — kept on the RIGHT (like desktop), sized to fit, above/behind the card */
    .work__word { font-size: 30vw; }
    /* background hills — natural + uncropped (a low band); do NOT crop the top.
       (desktop width:100% / height:auto already reads as a low band on a phone) */
    /* foreground hillside — full mobile width, ORIGINAL orientation (spans to the right) */
    .work__front {
      right: auto;
      left: 50%;
      width: 104%;
      transform: translateX(-50%);
    }
    /* biker — centred, standing on the foreground road (a touch bigger) */
    .work__biker {
      right: auto;
      left: 50%;
      transform: translateX(-50%);
      bottom: 1%;
      height: clamp(180px, 47vw, 235px);
    }
  }
</style>

<script>
  const work = document.querySelector<HTMLElement>("[data-work]");
  if (work) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduce) {
      // prime the entrance reveal (sets initial hidden states via CSS)
      work.classList.add("reveal-ready");
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0]?.isIntersecting) {
            work.classList.add("is-in");
            // let the carousel sync its first shader burst to the entrance
            window.dispatchEvent(new CustomEvent("work:revealed"));
            io.disconnect();
          }
        },
        { threshold: 0.08 },
      );
      io.observe(work);
    }
  }
</script>

<script>
  // animated cyclist (Rive) — mirrors the hero island: boot + dispose across
  // View-Transition swaps so the WASM instance never leaks.
  import { initWorkCyclist } from "../scripts/work/cyclist";

  let cleanup: (() => void) | void;
  const boot = () => { cleanup?.(); cleanup = initWorkCyclist(); };

  boot(); // initial load
  document.addEventListener("astro:before-swap", () => cleanup?.());
  document.addEventListener("astro:after-swap", boot);
</script>
