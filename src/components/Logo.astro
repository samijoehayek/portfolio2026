---
// SajeLabs / Samijoe Hayek logo — lowercase "sh" monogram in the block/rounded style
// of the daveholloway "dh" mark. Rendered in `currentColor` so it inherits the
// surrounding text colour (black in the navbar over the blue header). The same mark
// ships on the brand-blue tile as public/favicon.svg + the PWA/OG icon set.
interface Props {
  size?: number; // rendered height in px
  class?: string;
}
const { size = 40, class: className = "" } = Astro.props;
const AR = 1355 / 1162; // native aspect (width / height)
---

<svg
  class={`logo ${className}`}
  width={Math.round(size * AR)}
  height={size}
  viewBox="0 0 1355 1162"
  role="img"
  aria-label="Samijoe Hayek — home"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
>
  <g transform="translate(0,1162) scale(0.1,-0.1)">
