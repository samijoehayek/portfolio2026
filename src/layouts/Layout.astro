---
import "../styles/tokens.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Portfolio",
  description = "A neo-brutalist creative portfolio.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="lenis">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Free stand-in fonts (swap for licensed faces later) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@700;800;900&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-frame" aria-hidden="true"></div>
    <slot />

    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";

      // Expose GSAP + Lenis globally so component islands can share them.
      const w = window as typeof window & {
        gsap?: typeof gsap;
        lenis?: Lenis;
      };
      w.gsap = gsap;

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const lenis = new Lenis({
        lerp: 0.1,
        smoothWheel: !prefersReduced,
      });
      w.lenis = lenis;

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Let other islands know Lenis is ready.
      window.dispatchEvent(new CustomEvent("lenis:ready"));
    </script>
  </body>
</html>
