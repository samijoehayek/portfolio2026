---
import "../styles/tokens.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string; // absolute URL or root-relative path (e.g. /lab/og/x.png)
  ogType?: string; // "website" | "article"
}

const {
  title = "Samijoe Hayek — Full-stack engineer",
  description =
    "Samijoe Hayek — full-stack engineer building products end to end: blockchain, back-end, and the interfaces that tie them together.",
  ogImage = "/og-image.png",
  ogType = "website",
} = Astro.props;

const SITE = Astro.site ?? new URL("https://samijoehayek.com");
const canonical = new URL(Astro.url.pathname, SITE);
const ogImageURL = new URL(ogImage, SITE);
---

<!doctype html>
<html lang="en" class="lenis">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Favicons / PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#2b47ff" />
    <link rel="alternate" type="application/rss+xml" title="The Lab" href="/lab/rss.xml" />

    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Samijoe Hayek" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Free stand-in fonts (swap for licensed faces later) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@700;800;900&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- per-page extras: article meta, JSON-LD structured data, etc. -->
    <slot name="head" />
  </head>
  <body>
    <div class="site-frame" aria-hidden="true"></div>
    <slot />

    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";

      // Expose GSAP + Lenis globally so component islands can share them.
      const w = window as typeof window & {
        gsap?: typeof gsap;
        lenis?: Lenis;
      };
      w.gsap = gsap;

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const lenis = new Lenis({
        lerp: 0.1,
        smoothWheel: !prefersReduced,
      });
      w.lenis = lenis;

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Let other islands know Lenis is ready.
      window.dispatchEvent(new CustomEvent("lenis:ready"));
    </script>
  </body>
</html>
